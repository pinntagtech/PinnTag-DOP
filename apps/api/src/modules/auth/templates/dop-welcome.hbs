<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width">
  <title>Welcome to PinnTag DOP</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont,
        'Segoe UI', sans-serif;
      background: #F4F4F5;
      margin: 0;
      padding: 40px 20px;
    }
    .card {
      max-width: 480px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .header {
      background: #0A0A0A;
      padding: 32px;
      text-align: center;
    }
    .header h1 {
      color: #ffffff;
      font-size: 20px;
      margin: 0;
      font-weight: 600;
    }
    .header p {
      color: #A1A1AA;
      font-size: 13px;
      margin: 4px 0 0;
    }
    .body {
      padding: 32px;
    }
    .body p {
      color: #3F3F46;
      font-size: 14px;
      line-height: 1.6;
      margin: 0 0 16px;
    }
    .credentials {
      background: #F4F4F5;
      border-radius: 8px;
      padding: 20px;
      margin: 24px 0;
    }
    .credentials .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #71717A;
      font-weight: 500;
      margin-bottom: 4px;
    }
    .credentials .value {
      font-size: 14px;
      color: #0A0A0A;
      font-weight: 500;
      font-family: monospace;
      word-break: break-all;
    }
    .credentials .row {
      margin-bottom: 16px;
    }
    .credentials .row:last-child {
      margin-bottom: 0;
    }
    .role-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 600;
      background: #E4E4E7;
      color: #0A0A0A;
      text-transform: capitalize;
    }
    .btn {
      display: block;
      width: 100%;
      padding: 12px;
      background: #0A0A0A;
      color: #ffffff;
      text-align: center;
      text-decoration: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      margin: 24px 0 0;
      box-sizing: border-box;
    }
    .footer {
      padding: 20px 32px;
      border-top: 1px solid #E4E4E7;
      font-size: 12px;
      color: #A1A1AA;
      text-align: center;
    }
    .warning {
      background: #FFF7ED;
      border: 1px solid #FED7AA;
      border-radius: 6px;
      padding: 12px 16px;
      font-size: 13px;
      color: #C2410C;
      margin-top: 16px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <h1>PinnTag DOP</h1>
      <p>Data Operations Platform</p>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>,</p>
      <p>
        You've been added to the PinnTag Data Operations
        Platform. Here are your login credentials:
      </p>
      <div class="credentials">
        <div class="row">
          <div class="label">Email</div>
          <div class="value">{{email}}</div>
        </div>
        <div class="row">
          <div class="label">Password</div>
          <div class="value">{{password}}</div>
        </div>
        <div class="row">
          <div class="label">Role</div>
          <div class="value">
            <span class="role-badge">{{role}}</span>
          </div>
        </div>
        <div class="row">
          <div class="label">Environments</div>
          <div class="value">{{environments}}</div>
        </div>
      </div>
      <div class="warning">
        ⚠️ Please change your password after first login.
        Do not share these credentials with anyone.
      </div>
      <a href="{{loginUrl}}" class="btn">
        Sign in to DOP →
      </a>
    </div>
    <div class="footer">
      This email was sent by PinnTag DOP.
      If you didn't expect this, please ignore it.
    </div>
  </div>
</body>
</html>
